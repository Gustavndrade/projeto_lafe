      "name": "6. Busca Combinada",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}?page=1&limit=20&search=admin&role=admin",
          "host": ["{{baseUrl}}"],
          "query": [
            {
              "key": "page",
              "value": "1"
