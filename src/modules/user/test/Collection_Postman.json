      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Robert Lindomar\",\n  \"email\": \"robert@gmail.com\",\n  \"password\": \"123456\",\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}",
          "host": ["{{baseUrl}}"]
        },
        "description": "Cria um novo usuário no sistema"
      },
      "response": [
        {
          "name": "Sucesso - Usuário Criado",
          "originalRequest": {
            "method": "POST",
